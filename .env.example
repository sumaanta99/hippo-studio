# Hippo backend URL (used by Next.js rewrites — server-side only)
HIPPO_API_URL=https://hippo-api.onrender.com

# Browser-facing API path. Keep as /backend to use the Next.js proxy (recommended).
NEXT_PUBLIC_HIPPO_API_URL=/backend

# Public site URL for SEO metadata and sitemap (your Vercel URL after deploy)
NEXT_PUBLIC_SITE_URL=https://your-studio.vercel.app

# Copy from Render dashboard → hippo-api → Environment → ANALYTICS_ADMIN_KEY
# Local only — for `npm run analytics`. Do NOT add to Netlify.
ANALYTICS_ADMIN_KEY=
